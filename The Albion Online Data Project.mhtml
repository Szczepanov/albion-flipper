    <div class=3D"page api-page">
  <header class=3D"site-header">
    <div class=3D"site-header__inner">
      <h1 class=3D"site-title"><a href=3D"https://www.albion-online-data.co=
m/">The Albion Online Data Project</a></h1>
      <p class=3D"site-tagline">Realtime market and gold data for Albion On=
line</p>
      <nav class=3D"site-nav">
  <a href=3D"https://www.albion-online-data.com/">Home</a>
  <a href=3D"https://www.albion-online-data.com/client">Client</a>
